     "ccls.cacheDirectory": "/spare/ssd/${env:USERNAME}/.ccls-cache",
     // This setting makes it so that ccls doesn't index all files at start-up, and
     // instead files are only indexed on demand as you open them. This makes start-up
     // much quicker although you lose certain things like being able to list all
     // places where a function is called from.
     "ccls.index.initialBlacklist": ["."],
     "ccls.diagnostics.blacklist": ["gitlens:*", "git:*", ".*/.conda/.*"],
     "ccls.index.threads": 3,
     "ccls.index.trackDependency": 0,
     "ccls.completion.enableSnippetInsertion": true,
     "ccls.misc.showInactiveRegions": false,
     "ccls.index.multiVersion": 1,

